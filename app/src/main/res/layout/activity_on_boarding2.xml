<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.splashScreen.OnBoardingActivity2">

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/buttonSkip"
        android:layout_width="75dp"
        android:layout_height="48dp"
        android:layout_alignParentEnd="true"
        android:layout_marginHorizontal="26dp"
        android:layout_marginTop="30dp"
        android:background="@drawable/skip_btn_layout"
        android:backgroundTint="@null"
        android:fontFamily="@font/inter_bold"
        android:text="Skip"
        android:textColor="#fff"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/image_layout"
        android:layout_width="match_parent"
        android:layout_height="329dp"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@+id/buttonSkip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="328dp"
            android:layout_height="328dp"
            android:layout_gravity="center"
            android:backgroundTint="#D9D9DF"
            app:cardCornerRadius="185dp"
            app:cardElevation="5dp"
            android:layout_marginHorizontal="30dp">

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="286dp"
            android:layout_height="286dp"
            app:cardCornerRadius="185dp"
            android:layout_gravity="center"
            app:cardElevation="10dp"
            android:layout_marginHorizontal="30dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:textAlignment="center"
                android:contentDescription="easy_service"
                android:src="@drawable/easy_service"
                android:scaleType="centerCrop"/>

        </androidx.cardview.widget.CardView>

    </FrameLayout>

    <TextView
        android:id="@+id/page_desc"
        android:layout_width="343dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="47dp"
        android:padding="8dp"
        android:fontFamily="@font/abeezee"
        android:text="@string/onBoardingText2"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="28sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/image_layout" />



    <androidx.cardview.widget.CardView
        android:id="@+id/buttonNext_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/page_desc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <ImageButton
            android:id="@+id/buttonNext"
            android:layout_width="51dp"
            android:layout_height="51dp"
            android:background="#FC10101C"
            android:contentDescription="next_btn"
            android:src="@drawable/ic_arrow_right"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>