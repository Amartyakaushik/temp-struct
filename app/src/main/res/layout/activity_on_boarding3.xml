<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.splashScreen.OnBoardingActivity3">

    <FrameLayout
        android:id="@+id/image_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="79dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="328dp"
            android:layout_height="328dp"
            android:layout_gravity="center"
            android:backgroundTint="#D9D9DF"
            app:cardCornerRadius="185dp"
            app:cardElevation="5dp"
            android:layout_marginHorizontal="30dp">

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="286dp"
            android:layout_height="286dp"
            app:cardCornerRadius="185dp"
            android:layout_gravity="center"
            app:cardElevation="10dp"
            android:layout_marginHorizontal="30dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:textAlignment="center"
                android:src="@drawable/beauty_parlor_at_home"
                android:scaleType="centerCrop"/>

        </androidx.cardview.widget.CardView>

    </FrameLayout>

    <TextView
        android:id="@+id/page_desc"
        android:layout_width="355dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="47dp"
        android:padding="4dp"
        android:fontFamily="@font/abeezee"
        android:text="@string/onBoardingScreen3Description"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="28sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/image_layout" />



        <androidx.appcompat.widget.AppCompatButton
            android:background="@drawable/btn_custom_background"
            android:id="@+id/buttonNext"
            android:layout_width="wrap_content"
            android:layout_height="51dp"
            android:elevation="10dp"
            android:text="Get Started"
            android:paddingHorizontal="18dp"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/page_desc"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>