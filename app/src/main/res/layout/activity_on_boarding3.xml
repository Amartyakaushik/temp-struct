<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.splashScreen.onBoardingActivity3">

    <FrameLayout
        android:id="@+id/image_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="328dp"
            android:layout_height="328dp"
            android:layout_gravity="center"
            android:backgroundTint="#F2F4FF"
            app:cardCornerRadius="185dp"
            app:cardElevation="5dp"
            android:layout_marginHorizontal="30dp">

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="286dp"
            android:layout_height="286dp"
            app:cardCornerRadius="185dp"
            android:layout_gravity="center"
            app:cardElevation="10dp"
            android:layout_marginHorizontal="30dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:textAlignment="center"
                android:src="@drawable/beauty_parlor_at_home"
                android:scaleType="centerCrop"/>

        </androidx.cardview.widget.CardView>

    </FrameLayout>

    <TextView
        android:id="@+id/page_desc"
        android:layout_width="355dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="47dp"
        android:padding="4dp"
        android:fontFamily="@font/abeezee"
        android:text="Get Beauty parlor at your  home &amp; other Personal Grooming needs"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="28sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/image_layout" />



    <androidx.cardview.widget.CardView
        android:id="@+id/buttonNext_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/page_desc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <ImageButton
            android:id="@+id/buttonNext"
            android:layout_width="51dp"
            android:layout_height="51dp"
            android:background="#283891"
            android:contentDescription="next_btn"
            android:src="@drawable/ic_arrow_right"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>