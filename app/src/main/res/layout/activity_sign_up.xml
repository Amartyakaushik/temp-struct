<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_layout"
    tools:context=".ui.authentication.SignUpActivity">

    <ImageButton
        android:id="@+id/nav_back"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:background="@android:color/transparent"
        android:contentDescription="nav_back"
        android:src="@drawable/img_4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white"
        tools:ignore="TouchTargetSizeCheck" />

    <TextView
        android:id="@+id/txt1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Create an \naccount"
        android:textSize="40sp"
        android:textColor="@color/white"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@+id/nav_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:gravity="center"/>

    <TextView
        android:id="@+id/txt2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sign up with"
        app:layout_constraintTop_toBottomOf="@+id/txt1"
        app:layout_constraintStart_toStartOf="@+id/txt1"
        app:layout_constraintEnd_toEndOf="@+id/txt1"
        android:textColor="#8DFFFFFF"
        android:layout_marginTop="20dp"
        android:textSize="17sp"
        android:gravity="center"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/google_btn"
        android:layout_width="160dp"
        android:layout_height="50dp"
        android:drawableStart="@drawable/ic_google"
        android:gravity="center"
        android:textAlignment="center"
        android:layout_marginHorizontal="50dp"
        android:layout_marginTop="15dp"
        android:background="@drawable/btn_custom_background"
        android:text="GOOGLE"
        android:textSize="18sp"
        android:paddingHorizontal="12dp"
        android:textColor="@color/white"
        app:layout_constraintTop_toBottomOf="@+id/txt2"
        app:layout_constraintStart_toStartOf="@+id/txt2"
        app:layout_constraintEnd_toEndOf="@+id/txt2"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="30dp"
        android:paddingVertical="10dp"
        app:layout_constraintStart_toStartOf="@+id/google_btn"
        app:layout_constraintTop_toBottomOf="@+id/google_btn"
        app:layout_constraintEnd_toEndOf="@+id/google_btn"
        android:orientation="vertical">
        <EditText
            android:id="@+id/user_name"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="40dp"
            android:inputType="text|textNoSuggestions|textCapWords"
            android:maxLines="1"
            android:singleLine="true"
            android:imeOptions="actionNext"
            android:maxLength="15"
            android:textColor="@color/hint_color"
            android:background="@drawable/edit_text_bg_log_in"
            android:hint="UserName"
            android:paddingHorizontal="10dp"
            android:textColorHint="#ffff" />
        <EditText
            android:id="@+id/email"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:inputType="textEmailAddress"
            android:maxLines="1"
            android:singleLine="true"
            android:imeOptions="actionNext"
            android:textColor="@color/hint_color"
            android:background="@drawable/edit_text_bg_log_in"
            android:hint="Email"
            android:paddingHorizontal="10dp"
            android:textColorHint="#ffff" />

        <EditText
            android:id="@+id/password"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:maxLines="1"
            android:singleLine="true"
            android:imeOptions="actionNext"
            android:maxLength="20"
            android:textColor="@color/hint_color"
            android:background="@drawable/edit_text_bg_log_in"
            android:hint="Password"
            android:inputType="textPassword"
            android:paddingHorizontal="10dp"
            android:textColorHint="#ffff" />

        <EditText
            android:id="@+id/cnfrm_password"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:maxLines="1"
            android:singleLine="true"
            android:imeOptions="actionDone"
            android:maxLength="20"
            android:textColor="@color/hint_color"
            android:background="@drawable/edit_text_bg_log_in"
            android:hint="Confirm Password"
            android:inputType="textPassword"
            android:paddingHorizontal="10dp"
            android:textColorHint="#ffff" />
        <androidx.appcompat.widget.AppCompatButton
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Register"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:background="@drawable/btn_custom_background"
            android:layout_marginTop="26dp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>