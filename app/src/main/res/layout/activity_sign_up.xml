<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.authentication.SignUpActivity">

    <ImageButton
        android:id="@+id/nav_back"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:background="@android:color/transparent"
        android:contentDescription="nav_back"
        android:src="@drawable/ic_nav_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/black"
        tools:ignore="TouchTargetSizeCheck" />
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="10dp"
        app:layout_constraintTop_toBottomOf="@+id/nav_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="30dp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@+id/txt2"
            app:layout_constraintStart_toStartOf="@+id/txt2"
            app:layout_constraintEnd_toEndOf="@+id/txt2">
            <TextView
                android:id="@+id/txt1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Create Account"
                android:textSize="25sp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="#1F41BB"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@+id/nav_back"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:gravity="center"/>

            <TextView
                android:id="@+id/txt2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sign up with"
                android:fontFamily="@font/poppins_semibold"
                app:layout_constraintTop_toBottomOf="@+id/txt1"
                app:layout_constraintStart_toStartOf="@+id/txt1"
                app:layout_constraintEnd_toEndOf="@+id/txt1"
                android:textColor="#494949"
                android:layout_marginTop="20dp"
                android:textSize="17sp"
                android:gravity="center"/>





            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/google_btn"
                android:layout_width="160dp"
                android:layout_height="50dp"
                android:drawableStart="@drawable/ic_google"
                android:gravity="center"
                android:elevation="25dp"
                android:textAlignment="center"
                android:layout_marginHorizontal="50dp"
                android:layout_marginTop="15dp"
                android:background="@drawable/btn_custom_background"
                android:text="GOOGLE"
                android:fontFamily="@font/poppins_semibold"
                android:textSize="18sp"
                android:paddingHorizontal="12dp"
                android:textColor="@color/white"
                app:layout_constraintTop_toBottomOf="@+id/txt2"
                app:layout_constraintStart_toStartOf="@+id/txt2"
                app:layout_constraintEnd_toEndOf="@+id/txt2"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="@+id/google_btn"
                app:layout_constraintTop_toBottomOf="@+id/google_btn"
                app:layout_constraintEnd_toEndOf="@+id/google_btn"
                android:orientation="vertical">
                <EditText
                    android:id="@+id/user_name"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="40dp"
                    android:inputType="text|textNoSuggestions|textCapWords"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:imeOptions="actionNext"
                    android:maxLength="25"
                    android:textSize="18sp"
                    android:textColor="@color/hint_color"
                    android:background="@drawable/edit_text_bg_log_in"
                    android:hint="UserName"
                    android:paddingHorizontal="10dp"
                    android:fontFamily="@font/poppins"
                    android:textColorHint="@color/hintColor" />
                <EditText
                    android:id="@+id/email"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:inputType="textEmailAddress"
                    android:maxLines="1"
                    android:textSize="18sp"
                    android:singleLine="true"
                    android:imeOptions="actionNext"
                    android:textColor="@color/hint_color"
                    android:background="@drawable/edit_text_bg_log_in"
                    android:hint="Email"
                    android:paddingHorizontal="10dp"
                    android:fontFamily="@font/poppins"
                    android:textColorHint="@color/hintColor" />
                <EditText
                    android:id="@+id/phoneNumber"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:inputType="numberDecimal"
                    android:maxLines="1"
                    android:maxEms="10"
                    android:textSize="18sp"
                    android:singleLine="true"
                    android:imeOptions="actionNext"
                    android:textColor="@color/hint_color"
                    android:background="@drawable/edit_text_bg_log_in"
                    android:hint="Enter Phone Number"
                    android:paddingHorizontal="10dp"
                    android:fontFamily="@font/poppins"
                    android:textColorHint="@color/hintColor" />

                <EditText
                    android:id="@+id/password"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:maxLines="1"
                    android:textSize="18sp"
                    android:singleLine="true"
                    android:imeOptions="actionNext"
                    android:maxLength="25"
                    android:inputType="textPassword"
                    android:textColor="@color/hint_color"
                    android:background="@drawable/edit_text_bg_log_in"
                    android:hint="Password"
                    android:paddingHorizontal="10dp"
                    android:fontFamily="@font/poppins"
                    android:textColorHint="@color/hintColor"/>

                <EditText
                    android:id="@+id/cnfrm_password"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:maxLines="1"
                    android:textSize="18sp"
                    android:singleLine="true"
                    android:imeOptions="actionDone"
                    android:maxLength="25"
                    android:textColor="@color/hint_color"
                    android:background="@drawable/edit_text_bg_log_in"
                    android:hint="Confirm Password"
                    android:inputType="textPassword"
                    android:paddingHorizontal="10dp"
                    android:fontFamily="@font/poppins"
                    android:textColorHint="@color/hintColor" />
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/regstr_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:elevation="25dp"
                    android:text="Register"
                    android:textSize="18sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/white"
                    android:background="@drawable/btn_custom_background"
                    android:layout_marginTop="26dp"/>

            </LinearLayout>
            <Button
                android:id="@+id/nav_login"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Already have an account"
                android:fontFamily="@font/poppins_semibold"
                android:background="@android:color/transparent"
                android:textColor="#494949"
                android:layout_marginTop="9dp"/>
        </LinearLayout>



    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>