<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:orientation="vertical"
android:id="@+id/payment_credit"
tools:context=".ui.account.helpandsupport.help.PaymentAndCreditFragment"
android:background="@android:color/white">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:padding="10dp"
    android:layout_marginTop="5dp"
    >

    <TextView
        android:id="@+id/profileName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginTop="10dp"
        android:text="Payment &amp; WorkA1 Credits"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:textSize="25sp" />

</LinearLayout>
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:backgroundTint="#E2DBDB"
        android:background="@android:color/darker_gray"/>


    <androidx.recyclerview.widget.RecyclerView
    android:layout_width="match_parent"
    android:id="@+id/payment_credit_recycler_view"
    android:layout_height="match_parent"
    android:layout_marginTop="10dp"

    />
</LinearLayout>

