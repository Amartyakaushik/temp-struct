    <fragment
        android:id="@+id/navigation_membership"
        android:name="com.example.worka1.ui.account.helpandsupport.help.MembershipFragment"
        android:label="Plus membership"
        tools:layout="@layout/fragment_membership" />
    <fragment
        android:id="@+id/navigation_safety"
        android:name="com.example.worka1.ui.account.helpandsupport.help.SafetyFragment"
        android:label="Safety"
        tools:layout="@layout/fragment_safety" />
    <fragment
        android:id="@+id/navigation_claim_warranty"
        android:name="com.example.worka1.ui.account.helpandsupport.help.ClaimWarrantyFragment"
